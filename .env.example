# ── Model selection ────────────────────────────────────────────────────────
# Which adapter the router uses.
# Options: local, claude, openai, gemini, grok, deepseek, github
A0_MODEL=local

# ── LLM API Keys ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
DEEPSEEK_API_KEY=

# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Google Cloud ───────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
